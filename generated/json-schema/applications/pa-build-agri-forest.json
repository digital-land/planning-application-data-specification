{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "$id": "pa-build-agri-forest.json",
  "title": "Prior approval: Agricultural or forestry building development",
  "additionalProperties": true,
  "description": "Prior apporval for building development related to agricultural and forestry buildings",
  "type": "object",
  "properties": {
    "agent-contact": {
      "$ref": "#/definitions/agent-contact"
    },
    "agent-details": {
      "$ref": "#/definitions/agent-details"
    },
    "agri-forest-dev-elig": {
      "$ref": "#/definitions/agri-forest-dev-elig"
    },
    "applicant-contact": {
      "$ref": "#/definitions/applicant-contact"
    },
    "applicant-details": {
      "$ref": "#/definitions/applicant-details"
    },
    "checklist": {
      "$ref": "#/definitions/checklist"
    },
    "conflict-of-interest": {
      "$ref": "#/definitions/conflict-of-interest"
    },
    "declaration": {
      "$ref": "#/definitions/declaration"
    },
    "proposed-building": {
      "$ref": "#/definitions/proposed-building"
    },
    "site-details": {
      "$ref": "#/definitions/site-details"
    }
  },
  "required": [
    "agent-contact",
    "agent-details",
    "agri-forest-dev-elig",
    "applicant-contact",
    "applicant-details",
    "checklist",
    "conflict-of-interest",
    "declaration",
    "proposed-building",
    "site-details"
  ],
  "definitions": {
    "contact-details": {
      "type": "object",
      "properties": {
        "email": {
          "type": "string"
        },
        "phone-numbers": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/phone-number"
          },
          "minItems": 1
        }
      },
      "required": [
        "email",
        "phone-numbers"
      ]
    },
    "applicant": {
      "type": "object",
      "properties": {
        "reference": {
          "type": "string"
        },
        "person": {
          "$ref": "#/definitions/person"
        }
      },
      "required": [
        "reference",
        "person"
      ]
    },
    "building-details": {
      "type": "object",
      "properties": {
        "details": {
          "type": "string"
        },
        "building-length": {
          "type": "number"
        },
        "eaves-height": {
          "type": "number"
        },
        "building-breadth": {
          "type": "number"
        },
        "building-ridge-height": {
          "type": "number"
        }
      },
      "required": [
        "details",
        "building-length",
        "eaves-height",
        "building-breadth",
        "building-ridge-height"
      ]
    },
    "site-location": {
      "type": "object",
      "properties": {
        "site-boundary": {
          "type": "string"
        },
        "address-text": {
          "type": "string"
        },
        "postcode": {
          "type": "string"
        },
        "easting": {
          "type": "number"
        },
        "northing": {
          "type": "number"
        },
        "latitude": {
          "type": "number"
        },
        "longitude": {
          "type": "number"
        },
        "description": {
          "type": "string"
        },
        "uprns": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        }
      },
      "required": []
    },
    "person": {
      "type": "object",
      "properties": {
        "title": {
          "type": "string"
        },
        "first-name": {
          "type": "string"
        },
        "last-name": {
          "type": "string"
        },
        "address-text": {
          "type": "string"
        },
        "postcode": {
          "type": "string"
        }
      },
      "required": [
        "first-name",
        "last-name",
        "address-text"
      ]
    },
    "phone-number": {
      "type": "object",
      "properties": {
        "number": {
          "type": "string"
        },
        "contact-priority": {
          "type": "string",
          "enum": [
            "primary",
            "secondary"
          ]
        }
      },
      "required": []
    },
    "agent": {
      "type": "object",
      "properties": {
        "reference": {
          "type": "string"
        },
        "person": {
          "$ref": "#/definitions/person"
        },
        "company": {
          "type": "string"
        },
        "user-role": {
          "type": "string",
          "enum": [
            "agent",
            "proxy"
          ]
        }
      },
      "required": [
        "reference",
        "person"
      ]
    },
    "site-details": {
      "type": "object",
      "properties": {
        "site-locations": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/site-location"
          },
          "minItems": 1
        }
      },
      "required": [
        "site-locations"
      ]
    },
    "agent-details": {
      "type": "object",
      "properties": {
        "agent": {
          "$ref": "#/definitions/agent"
        }
      },
      "required": []
    },
    "applicant-details": {
      "type": "object",
      "properties": {
        "applicants": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/applicant"
          },
          "minItems": 1
        }
      },
      "required": [
        "applicants"
      ]
    },
    "applicant-contact": {
      "type": "object",
      "properties": {
        "applicant-reference": {
          "type": "string"
        },
        "contact-details": {
          "$ref": "#/definitions/contact-details"
        }
      },
      "required": [
        "applicant-reference",
        "contact-details"
      ]
    },
    "agent-contact": {
      "type": "object",
      "properties": {
        "agent-reference": {
          "type": "string"
        },
        "contact-details": {
          "$ref": "#/definitions/contact-details"
        }
      },
      "required": [
        "agent-reference",
        "contact-details"
      ]
    },
    "conflict-of-interest": {
      "type": "object",
      "properties": {},
      "required": []
    },
    "agri-forest-dev-elig": {
      "type": "object",
      "properties": {
        "agri-unit-area": {
          "type": "number"
        },
        "land-parcel-area": {
          "type": "string",
          "enum": [
            "1-hec-or-more",
            "less-1-more-point4-hec",
            "less-point4.hec"
          ]
        },
        "agri-start-date": {
          "type": "string"
        },
        "is-necessary-for-agri": {
          "type": "boolean"
        },
        "details": {
          "type": "string"
        },
        "is-designed-agri": {
          "type": "boolean"
        },
        "design-details": {
          "type": "string"
        },
        "dwelling-alteration": {
          "type": "boolean"
        },
        "away-from-road": {
          "type": "boolean"
        },
        "close-to-aerodrome": {
          "type": "boolean"
        },
        "proposed-height": {
          "type": "number"
        },
        "affects-heritage": {
          "type": "boolean"
        },
        "heritage-nature-impact-details": {
          "type": "string"
        }
      },
      "required": [
        "agri-unit-area",
        "land-parcel-area",
        "agri-start-date",
        "is-necessary-for-agri",
        "is-designed-agri",
        "dwelling-alteration",
        "away-from-road",
        "close-to-aerodrome",
        "proposed-height",
        "affects-heritage"
      ],
      "allOf": [
        {
          "if": {
            "properties": {
              "is-necessary-for-agri": {
                "const": true
              }
            }
          },
          "then": {
            "required": [
              "details"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "is-designed-agri": {
                "const": true
              }
            }
          },
          "then": {
            "required": [
              "design-details"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "affects-heritage": {
                "const": true
              }
            }
          },
          "then": {
            "required": [
              "heritage-nature-impact-details"
            ]
          }
        }
      ]
    },
    "checklist": {
      "type": "object",
      "properties": {
        "national-req-types": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        }
      },
      "required": [
        "national-req-types"
      ]
    },
    "proposed-building": {
      "type": "object",
      "properties": {
        "development-operation-types": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "new-build",
              "extension",
              "alteration"
            ]
          },
          "minItems": 1
        },
        "proposed-building-details": {
          "$ref": "#/definitions/building-details"
        },
        "building-wall-materials": {
          "type": "string"
        },
        "building-wall-colour": {
          "type": "string"
        },
        "building-roof-materials": {
          "type": "string"
        },
        "building-roof-colour": {
          "type": "string"
        },
        "has-agri-building-2-yrs": {
          "type": "boolean"
        },
        "agri-building-area": {
          "type": "number"
        },
        "agri-building-distance": {
          "type": "number"
        },
        "house-livestock": {
          "type": "boolean"
        },
        "livestock-building-400m": {
          "type": "boolean"
        },
        "exceeds-threshold": {
          "type": "boolean"
        },
        "related-work-distance": {
          "type": "boolean"
        },
        "engineering-operations-threshold": {
          "type": "string",
          "enum": [
            "yes",
            "no",
            "not-applicable"
          ]
        },
        "within-scheduled-monument": {
          "type": "boolean"
        }
      },
      "required": [
        "development-operation-types",
        "proposed-building-details",
        "building-wall-materials",
        "building-wall-colour",
        "building-roof-materials",
        "building-roof-colour",
        "has-agri-building-2-yrs",
        "house-livestock",
        "exceeds-threshold",
        "related-work-distance",
        "engineering-operations-threshold",
        "within-scheduled-monument"
      ],
      "allOf": [
        {
          "if": {
            "properties": {
              "has-agri-building-2-yrs": {
                "const": true
              }
            }
          },
          "then": {
            "required": [
              "agri-building-area"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "has-agri-building-2-yrs": {
                "const": true
              }
            }
          },
          "then": {
            "required": [
              "agri-building-distance"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "house-livestock": {
                "const": true
              }
            }
          },
          "then": {
            "required": [
              "livestock-building-400m"
            ]
          }
        }
      ]
    },
    "declaration": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "declaration-confirmed": {
          "type": "boolean"
        },
        "declaration-date": {
          "type": "string"
        }
      },
      "required": [
        "name",
        "declaration-confirmed",
        "declaration-date"
      ]
    }
  }
}